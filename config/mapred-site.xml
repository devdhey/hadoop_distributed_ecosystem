<configuration>
  <property>
    <name>mapreduce.framework.name</name>
    <value>yarn</value>
  </property>

  <!-- Definindo o quanto de memoria cada tarefa do map reduce pode usar -->
  <property>
    <name>mapreduce.map.memory-mb</name>
    <value>800</value> <!-- Quantidade de RAM que cada tarefa de mapeamento pode usar -->
  </property>

  <property>
    <name>mapreduce.reduce.memory-mb</name>
    <value>800</value> <!-- Quantidade de RAM que cada tarefa de redução pode usar -->
  </property>

  <property>
    <name>mapreduce.map.java.opts</name>
    <value>-Xmx640m</value> <!-- Opções JVM para tarefas de mapeamento (80% da RAM alocada) -->
  </property> <!-- isso evita erros de memoria fisica -->

  <property>
    <name>mapreduce.reduce.java.opts</name>
    <value>-Xmx640m</value> <!-- Opções JVM para tarefas de redução (80% da RAM alocada) -->
  </property> <!-- isso evita erros de memoria fisica -->

  <!-- Caminho para o hadoop escutar a pasta correta -->
  <property>
    <name>yarn.app.mapreduce.am.env</name>
    <value>HADOOP_MAPRED_HOME=/opt/hadoop</value> <!-- Define a variável de ambiente HADOOP_MAPRED_HOME para o Application Master do MapReduce, apontando para o diretório de instalação do Hadoop. Ajuste o caminho conforme necessário para refletir a estrutura do seu ambiente. -->
  </property>

  <property>
    <name>mapreduce.map.env</name>
    <value>HADOOP_MAPRED_HOME=/opt/hadoop</value> <!-- Define a variável de ambiente HADOOP_MAPRED_HOME para as tarefas de mapeamento, apontando para o diretório de instalação do Hadoop. Ajuste o caminho conforme necessário para refletir a estrutura do seu ambiente. -->
  </property>

  <property>
    <name>mapreduce.reduce.env</name>
    <value>HADOOP_MAPRED_HOME=/opt/hadoop</value> <!-- Define a variável de ambiente HADOOP_MAPRED_HOME para as tarefas de redução, apontando para o diretório de instalação do Hadoop. Ajuste o caminho conforme necessário para refletir a estrutura do seu ambiente. -->
  </property>

  
</configuration>