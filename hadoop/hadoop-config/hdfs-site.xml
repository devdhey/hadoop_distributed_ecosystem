<configuration>
  <property>
    <name>dfs.replication</name>
    <value>2</value> <!-- Replica em 2 o conteúdo do HDFS, 1 original e 1 replica, garantindo tolerância a falhas -->
  </property>

  <property>
    <name>dfs.namenode.name.dir</name>  <!-- Define o diretório onde o NameNode armazenará os metadados do HDFS. No caso de um ambiente local, usamos um diretório no sistema de arquivos local. Em um cluster real, isso geralmente apontaria para um armazenamento distribuído ou um sistema de arquivos local em cada nó do cluster. -->
    <value>file:///hadoop/dfs/name</value>
  </property>

  <property>
    <name>dfs.datanode.data.dir</name>
    <value>file:///hadoop/dfs/data</value>
  </property>

  <property>
    <name>dfs.namenode.rpc-address</name>
    <value>namenode:8020</value>
  </property>
<!-- Limitar o tamanho do Datanode -->
<!-- 
<property>
  <name>dfs.datanode.du.reserved</name>
  <value>10737418240</value> Reservar 10 GB para o sistema operacional 
-->
<!-- Aumentando o tempo que o hadoop espera antes de liberar o cluster-->
<!--
-->
  <property>
    <name>dfs.namenode.safemode.extension</name>
    <value>3000</value>
  </property>

  <property>
    <name>dfs.namenode.safemode.threshold-pct</name>
    <value>0.90</value>
  </property>

</configuration>
<!-- hdfs-site.xml configura o HDFS, é onde você decide como os arquivos serão tratados fisicamente-->
